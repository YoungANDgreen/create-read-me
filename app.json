{
  "expo": {
    "name": "GridIron IQ",
    "slug": "gridiron-iq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gridironiq",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gridironiq.app",
      "buildNumber": "1"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-haptics"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
